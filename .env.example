# Happyhappyhappy environment variables
# Copy this to .env and fill in values

# Gemini API key (free) — get at aistudio.google.com
GEMINI_API_KEY=

# Resend API key — for morning email digest
RESEND_API_KEY=

# Cloudflare deployment
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional: admin token for manual ingest trigger
ADMIN_TOKEN=
